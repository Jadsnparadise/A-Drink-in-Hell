--- !u!114 &749447970
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 749447968}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9a385b5ffe3d7a241876ed7b183deb16, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  uiText: {fileID: 1247432047}
  dialogueLines:
  - sentence: "Ol\xE1, filho."
    displayDuration: 2
  - sentence: "H\xE1 quanto tempo n\xE3o conversamos\u2026"
    displayDuration: 3
  - sentence: "Tenho observado toda a sua jornada at\xE9 este momento, e creio que
      seus pecados j\xE1 foram pagos."
    displayDuration: 8
  - sentence: "Vi tamb\xE9m o quanto Satan\xE1s o afligiu, prendendo-o em um ciclo
      intermin\xE1vel para servi-lo."
    displayDuration: 8
  - sentence: Mas agora esse tempo chegou ao fim.
    displayDuration: 4
  - sentence: "Venha. Junte-se a mim e aos seus irm\xE3os na casa do Pai."
    displayDuration: 6
  - sentence: "Voc\xEA \xE9 bem-vindo aqui."
    displayDuration: 4
  endEventDelay: 0
  onDialogueStart:
    m_PersistentCalls:
      m_Calls:
      - m_Target: {fileID: 0}
        m_TargetAssemblyTypeName: 
        m_MethodName: 
        m_Mode: 0
        m_Arguments:
          m_ObjectArgument: {fileID: 0}
          m_ObjectArgumentAssemblyTypeName: 
          m_IntArgument: 0
          m_FloatArgument: 0
          m_StringArgument: 
          m_BoolArgument: 0
        m_CallState: 2
